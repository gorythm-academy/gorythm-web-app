# Backend (Express) — copy to .env on the server. Never commit .env.

NODE_ENV=production
PORT=5000

# Reverse-proxy hops for Express (nginx, ALB, Vercel). Omit to use default (1 hop).
# TRUST_PROXY=2  → two proxies in front of Node
# TRUST_PROXY=0  → Node exposed directly (no trusted reverse proxy)

# Must match the browser origin of your React app (no trailing slash).
# Example: https://yourdomain.com
FRONTEND_URL=

MONGODB_URI=

JWT_SECRET=
JWT_EXPIRES_SESSION=12h
JWT_EXPIRES_REMEMBER=90d

# Optional first boot (remove or rotate after setup)
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: comma-separated Stripe payment_method_types override
# STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=card

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
CONTACT_INBOX_EMAIL=

# Serverless only; leave unset on VPS
# VERCEL=
