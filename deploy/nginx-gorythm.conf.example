# Example Nginx config: React static site + Express API on the same VPS.
#
# Replace:
#   yourdomain.com      → main site (serves build/)
#   api.yourdomain.com  → reverse proxy to Node (PM2 on 127.0.0.1:5000)
#
# Paths:
#   Adjust root to where `npm run build` output lives (usually .../build).
#
# Install:
#   sudo cp deploy/nginx-gorythm.conf.example /etc/nginx/sites-available/gorythm
#   sudo ln -s /etc/nginx/sites-available/gorythm /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# SSL (after DNS points here):
#   sudo certbot --nginx -d yourdomain.com -d www.yourdomain.com -d api.yourdomain.com
#   (Certbot will add ssl_certificate lines; listen 443 blocks are optional until then.)
#
# Compression (often also in nginx.conf http {}):
#   gzip on;
#   gzip_types text/plain text/css application/javascript application/json application/xml image/svg+xml;
# Brotli (optional, needs ngx_brotli): same idea with brotli_types.
#
# Cache: CRA emits content-hashed filenames under /static/ — safe to cache "forever".
# index.html must stay short-cache or no-cache so users pick up new chunk names.

upstream gorythm_api {
    server 127.0.0.1:5000;
    keepalive 64;
}

# ---- Main site (React SPA) ----
server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com www.yourdomain.com;

    root /var/www/gorythm/build;
    index index.html;

    # Single Page App shell — never long-cache HTML (new deploy = new hashed assets)
    location = /index.html {
        add_header Cache-Control "no-cache";
    }

    # Single Page App: all non-file routes → index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Hashed JS/CSS/media from `react-scripts build`
    location /static/ {
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
        try_files $uri =404;
    }

    # `public/` assets (fixed names e.g. /preload/lcp-hero.* , /video/*) — bump ?v= or filename on change
    location /preload/ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        try_files $uri =404;
    }

    location /video/ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        try_files $uri =404;
    }

    # Raster fallbacks & icons outside /static/
    location ~* \.(js|css|png|jpg|jpeg|gif|webp|avif|ico|svg|woff2?|mp4|webm)$ {
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
        try_files $uri =404;
    }
}

# ---- API (Express) ----
server {
    listen 80;
    listen [::]:80;
    server_name api.yourdomain.com;

    client_max_body_size 25m;

    location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_pass http://gorythm_api;
    }
}
